{
  "name": "agenthub-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "agenthub": "./bin/agenthub"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "db:init": "scripts/db-init.sh",
    "db:start": "scripts/db-start.sh",
    "db:stop": "scripts/db-stop.sh",
    "agenthub": "bin/agenthub",
    "dev": "node --env-file=.env --experimental-strip-types --watch src/server.ts",
    "start": "node --env-file=.env --experimental-strip-types src/server.ts",
    "typecheck": "tsc --noEmit",
    "migrate": "node --env-file=.env --experimental-strip-types src/db/migrate.ts",
    "test": "node --experimental-strip-types --test tests/*.test.ts"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "fastify": "^5.2.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "typescript": "^5.7.2"
  }
}
